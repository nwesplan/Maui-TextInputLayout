<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Nwesp.Maui.Android.Samples.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:input="clr-namespace:Nwesp.Maui.Android.Controls;assembly=Nwesp.Maui.Android"
    x:Name="this">
    <VerticalStackLayout Padding="8" Spacing="10" x:Name="vsl">
        <Button
            Margin="4"
            Command="{Binding FilledCommand}"
            Text="Filled Text Input Layout Demos" />
        <Button
            Margin="4"
            Command="{Binding OutlineCommand}"
            Text="Outlined Text Input Layout Demos" />
        <input:TextInputLayout BoxBackgroundMode="Filled" EndIconClickedCommand="{x:Null}">
            <input:MaterialEntry />
        </input:TextInputLayout>
        <input:TextInputLayout BoxBackgroundMode="Filled">
            <input:MaterialEntry />
        </input:TextInputLayout>
        <input:TextInputLayout BoxBackgroundMode="Filled">
            <input:MaterialEntry />
        </input:TextInputLayout>
        <input:TextInputLayout BoxBackgroundMode="Filled">
            <input:MaterialEntry />
        </input:TextInputLayout>
        <input:TextInputLayout BoxBackgroundMode="Filled">
            <input:MaterialEntry />
        </input:TextInputLayout>
    </VerticalStackLayout>
</ContentPage>
